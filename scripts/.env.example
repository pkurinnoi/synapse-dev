# Agent dev-team environment — template. Copy to scripts/.env and fill (chmod 600).
GITLAB_GROUP=          # GitLab group path, e.g. your-group (used by the board queries)
GITLAB_TOKEN=          # GitLab PAT with api scope on your GitLab group
TELEGRAM_TOKEN=        # @BotFather bot token (bot must be a member of the chat)
TELEGRAM_CHAT_ID=      # numeric chat id (group chats are negative, e.g. -1001234567890)
CTO_AUTO_ACCEPT_MR=0   # gated CTO merge power; default OFF

# Note: tg-issue-bot.py (Telegram /issue bot) reuses GITLAB_GROUP, GITLAB_TOKEN,
# TELEGRAM_TOKEN, and TELEGRAM_CHAT_ID above. No additional variables are required.
